[Unit]
Description=OpenInfra protected runtime secret provisioning
Before=openinfra-migrate.service openinfra.service openinfra-web.service openinfra-team-sync.service

[Service]
Type=oneshot
User=root
Group=root
ExecStart=/opt/openinfra/venv/bin/openinfra-server-runtime ensure-secret
RemainAfterExit=yes
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/openinfra

[Install]
WantedBy=multi-user.target
