{
  "profile_id": "openinfra-multisite-observability-v1",
  "profile_version": 1,
  "scope": "pro-enterprise",
  "required_signals": [
    "api_availability",
    "api_latency",
    "agent_heartbeat",
    "database_replication",
    "jobs",
    "site_health"
  ],
  "thresholds": {
    "agent_lag_seconds": 120,
    "database_replica_lag_seconds": 5,
    "api_p95_seconds": 0.5,
    "job_oldest_ready_age_seconds": 300
  },
  "target_labels": [
    "region",
    "site",
    "service"
  ],
  "max_regional_routes": 10000
}
