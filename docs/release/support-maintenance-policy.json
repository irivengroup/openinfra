{
  "schema_version": 1,
  "epic": "EPIC-1806",
  "release_version": "0.32.8",
  "support_profiles": {
    "lite": {
      "service_hours": "business-hours-8x5-europe-paris",
      "channels": ["community", "email"],
      "targets": {
