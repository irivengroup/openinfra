OPENINFRA_POSTGRES_DB=openinfra
OPENINFRA_POSTGRES_USER=openinfra
OPENINFRA_POSTGRES_PASSWORD=
OPENINFRA_API_BIND=127.0.0.1
OPENINFRA_API_PORT=8080
OPENINFRA_API_RUNTIME=asgi
OPENINFRA_API_WORKERS=2
OPENINFRA_API_LIMIT_CONCURRENCY=1000
OPENINFRA_API_BACKLOG=2048
OPENINFRA_API_KEEPALIVE_SECONDS=5
OPENINFRA_DB_POOL_MIN_SIZE=1
OPENINFRA_DB_POOL_MAX_SIZE=8
OPENINFRA_DB_POOL_TIMEOUT_SECONDS=5
OPENINFRA_DB_POOL_MAX_IDLE_SECONDS=300
OPENINFRA_DB_POOL_MAX_LIFETIME_SECONDS=1800
OPENINFRA_DB_CONNECTION_BUDGET=80
OPENINFRA_IMAGE_TAG=0.30.8
OPENINFRA_BOOTSTRAP_TOKEN=
OPENINFRA_PGADMIN_EMAIL=admin@openinfra.tld
OPENINFRA_PGADMIN_PASSWORD=
OPENINFRA_PGADMIN_BIND=127.0.0.1
OPENINFRA_PGADMIN_PORT=5050
OPENINFRA_PGADMIN_IMAGE=dpage/pgadmin4:latest
OPENINFRA_WEB_BIND=127.0.0.1
OPENINFRA_WEB_PORT=2006
OPENINFRA_WEB_RUNTIME=asgi
OPENINFRA_WEB_WORKERS=2
OPENINFRA_WEB_LIMIT_CONCURRENCY=1000
OPENINFRA_WEB_BACKLOG=2048
OPENINFRA_WEB_KEEPALIVE_SECONDS=5
OPENINFRA_WEB_HTTP_MAX_CONNECTIONS=200
OPENINFRA_WEB_HTTP_MAX_KEEPALIVE_CONNECTIONS=50
OPENINFRA_WEB_HTTP_KEEPALIVE_EXPIRY_SECONDS=30
OPENINFRA_WEB_HTTP_CONNECT_TIMEOUT_SECONDS=2
OPENINFRA_WEB_HTTP_READ_TIMEOUT_SECONDS=30
OPENINFRA_WEB_HTTP_WRITE_TIMEOUT_SECONDS=30
OPENINFRA_WEB_HTTP_POOL_TIMEOUT_SECONDS=2
OPENINFRA_WEB_BACKEND_URL=http://api:8080
OPENINFRA_WEB_PUBLIC_API_BASE_URL=/api
OPENINFRA_WEB_PUBLIC_API_DOCS_BASE_URL=
OPENINFRA_WEB_BACKEND_BEARER_TOKEN=
OPENINFRA_WEB_ALLOW_INSECURE_BACKEND=true
OPENINFRA_WEB_EDITION=pro
OPENINFRA_WEB_AUTH_MODE=standard

# PostgreSQL HA, PgBouncer and bounded read routing (Pro/Enterprise)
OPENINFRA_DOCKER_SUBNET=172.30.0.0/24
OPENINFRA_POSTGRES_REPLICATION_USER=openinfra_replica
OPENINFRA_POSTGRES_REPLICATION_PASSWORD=
OPENINFRA_PGBOUNCER_IMAGE_TAG=1.25.2
OPENINFRA_PGBOUNCER_MAX_CLIENT_CONN=1000
OPENINFRA_PGBOUNCER_DEFAULT_POOL_SIZE=40
OPENINFRA_PGBOUNCER_MIN_POOL_SIZE=4
OPENINFRA_PGBOUNCER_RESERVE_POOL_SIZE=10
OPENINFRA_PGBOUNCER_MAX_DB_CONNECTIONS=80
OPENINFRA_PGBOUNCER_MAX_DB_CLIENT_CONNECTIONS=1000
OPENINFRA_PGBOUNCER_QUERY_WAIT_TIMEOUT=10
OPENINFRA_PGBOUNCER_IDLE_TRANSACTION_TIMEOUT=60
OPENINFRA_PGBOUNCER_TRANSACTION_TIMEOUT=120
OPENINFRA_DB_READ_ROUTING_ENABLED=true
OPENINFRA_DB_MAX_REPLICA_LAG_SECONDS=5
OPENINFRA_DB_REPLICA_PROBE_INTERVAL_SECONDS=2
OPENINFRA_DB_READ_FALLBACK_TO_PRIMARY=true
OPENINFRA_DB_READ_REQUIRE_RECOVERY=true
OPENINFRA_READ_CONSISTENCY_SECRET=
# Optional dedicated key; falls back to OPENINFRA_READ_CONSISTENCY_SECRET.
OPENINFRA_CURSOR_SIGNING_SECRET=
OPENINFRA_READ_AFTER_WRITE_TTL_SECONDS=10
